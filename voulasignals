<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>369 Tesla Frequency | Quantitative Excellence</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        :root { 
            --gold: #D4AF37; 
            --charcoal: #0a0a0a; 
        }
        
        body { 
            background-color: var(--charcoal); 
            color: #E2E8F0; 
            font-family: 'Inter', sans-serif; 
            overflow-x: hidden; 
            scroll-behavior: smooth;
            /* Premium radial depth */
            background: radial-gradient(circle at 50% -20%, #1a1a1a 0%, #0a0a0a 100%);
        }

        .serif { font-family: 'Playfair Display', serif; }
        .gold-text { color: var(--gold); }
        .gold-gradient { background: linear-gradient(135deg, #D4AF37 0%, #F1D592 50%, #B8860B 100%); }
        
        .card-glass { 
            background: rgba(255, 255, 255, 0.02); 
            backdrop-filter: blur(12px); 
            border: 1px solid rgba(212, 175, 55, 0.1); 
            transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); 
        }
        
        .card-glass:hover { 
            border: 1px solid rgba(212, 175, 55, 0.4); 
            transform: translateY(-8px);
            background: rgba(255, 255, 255, 0.04);
        }

        .btn-gold { 
            background: linear-gradient(135deg, #D4AF37 0%, #B8860B 100%); 
            color: #000; 
            font-weight: 600; 
            transition: all 0.3s ease; 
        }
        
        .btn-gold:hover { 
            transform: scale(1.03); 
            box-shadow: 0 0 30px rgba(212, 175, 55, 0.35); 
        }
        
        /* Profile Circle Styling */
        .profile-circle {
            width: 100%;
            max-width: 420px;
            aspect-ratio: 1/1;
            border-radius: 50%;
            overflow: hidden;
            border: 1px solid rgba(212, 175, 55, 0.3);
            box-shadow: 0 0 60px rgba(212, 175, 55, 0.08);
            margin: 0 auto;
            position: relative;
        }

        .profile-circle::after {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: 50%;
            box-shadow: inset 0 0 50px rgba(0,0,0,0.5);
            pointer-events: none;
        }

        .voula-img { 
            width: 100%; 
            height: 100%; 
            object-fit: cover; 
            display: block; 
            filter: grayscale(20%) contrast(105%);
        }

        .qr-frame { 
            width: 150px; 
            height: 150px; 
            background: #fff; 
            padding: 12px; 
            border-radius: 12px; 
            border: 1px solid var(--gold); 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            overflow: hidden;
            transition: transform 0.3s ease;
        }

        .qr-img { width: 100%; height: 100%; object-fit: contain; }

        .jp-text { 
            font-size: 0.7rem; 
            opacity: 0.5; 
            letter-spacing: 0.25em; 
            text-transform: uppercase; 
            margin-top: 6px; 
            display: block; 
            font-weight: 300;
        }

        .nav-link {
            position: relative;
            transition: color 0.3s ease;
        }

        .nav-link::after {
            content: '';
            position: absolute;
            width: 0;
            height: 1px;
            bottom: -4px;
            left: 0;
            background-color: var(--gold);
            transition: width 0.3s ease;
        }

        .nav-link:hover::after {
            width: 100%;
        }
    </style>
</head>
<body>

    <!-- Navigation -->
    <nav class="flex justify-between items-center px-8 py-8 max-w-7xl mx-auto">
        <div class="text-2xl serif font-bold tracking-[0.2em] gold-text uppercase">369 Tesla</div>
        <div class="hidden md:flex space-x-12 text-[10px] uppercase tracking-[0.3em] font-light text-gray-400">
            <a href="#" class="nav-link hover:text-[#D4AF37]">Philosophy</a>
            <a href="#" class="nav-link hover:text-[#D4AF37]">Performance</a>
            <a href="#connect" class="nav-link hover:text-[#D4AF37]">Contact</a>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-8 py-12 md:py-24 flex flex-col md:flex-row items-center gap-16">
        <div class="w-full md:w-1/2 order-2 md:order-1 relative">
            <div class="profile-circle bg-[#1a1a1a]">
                <img src="photo.jpg" alt="Voula" class="voula-img" onerror="this.src='photo.jpeg'">
            </div>
            <!-- Background glow for the image -->
            <div class="absolute -z-10 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[110%] h-[110%] bg-gold/5 blur-[100px] rounded-full"></div>
        </div>
        
        <div class="w-full md:w-1/2 order-1 md:order-2 space-y-8 text-left">
            <div class="inline-block px-3 py-1 border border-[#D4AF37] text-[10px] uppercase tracking-[0.3em] gold-text">
                Proprietary Quantitative Engine <span class="block text-[8px] opacity-60">独自の計量エンジン</span>
            </div>
            <h1 class="text-4xl md:text-7xl serif leading-tight">
                369 Tesla: The <span class="gold-text">Mathematical Edge</span>
